datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String             @id @default(cuid())
  moodleUsername  String             @unique
  moodleUserId    Int
  name            String
  email           String?
  mindboxPassword String?
  plan            Plan               @default(FREE)
  createdAt       DateTime           @default(now())
  lastSeenAt      DateTime?
  tasks           Task[]
  grades          Grade[]
  schedule        ClassSession[]
  pushSubs        PushSubscription[]
  notes             Note[]
  noteViewPositions NoteViewPosition[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Task {
  id                 String     @id @default(cuid())
  userId             String
  moodleAssignmentId Int?
  moodleCmId         Int?
  title              String
  courseId           Int?
  courseName         String?
  semester           Int?
  dueDate            DateTime?
  description        String?
  attachments        Json?
  status             TaskStatus @default(PENDING)
  isManual           Boolean    @default(false)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, moodleAssignmentId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, dueDate])
}

model Grade {
  id            String   @id @default(cuid())
  userId        String
  period        String
  periodName    String
  subjectCode   String
  subjectName   String
  group         String
  credits       Int
  finalGrade    Int?
  evalType      String?
  partialGrades Json?
  syncedAt      DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, subjectCode])
  @@index([userId])
  @@index([userId, period])
}

model ClassSession {
  id          String   @id @default(cuid())
  userId      String
  dayOfWeek   Int      // 0=Mon, 1=Tue, ... 6=Sun
  subjectName String
  startTime   String   // "13:00"
  endTime     String   // "15:00"
  room        String?
  professor   String?
  group       String?
  syncedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, dayOfWeek])
}

model Note {
  id            String             @id @default(cuid())
  userId        String
  content       String             @default("")
  color         String             @default("yellow")
  x             Int                @default(100)
  y             Int                @default(100)
  pinned        Boolean            @default(false)
  shared        Boolean            @default(false)
  courseId      Int?
  courseName    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewPositions NoteViewPosition[]

  @@index([userId])
  @@index([shared, courseId])
}

model NoteViewPosition {
  id     String @id @default(cuid())
  noteId String
  userId String
  x      Int    @default(100)
  y      Int    @default(100)
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId])
  @@index([userId])
}

enum Plan {
  FREE
  PREMIUM
}

enum TaskStatus {
  PENDING
  DONE
  ARCHIVED
}
